<?xml version="1.0"?>
<CLBConfig version="2.0" output="output/">
        <Geometry nx="512" ny="100">
		<MRT><Box/></MRT>
<!-- 		<WVelocity name="Inlet" nx='1' dx='5'><Box/></WVelocity>
		<EPressure name="Outlet" nx='1' dx='-5'><Box/></EPressure> -->
		<Wall  mask="ALL">
			<Box ny="1"/>
            <Box dy="-1"/>

            <Wedge dx="120" nx="20" dy="50" ny="20" direction="LowerRight"/>
			<Wedge dx="120" nx="20" dy="30" ny="20" direction="UpperRight"/>
			<Wedge dx="140" nx="20" dy="50" ny="20" direction="LowerLeft"/>
			<Wedge dx="140" nx="20" dy="30" ny="20" direction="UpperLeft"/>
		</Wall>

		<None name="bubble">
    		<!-- <Sphere ny="56" nx="56" dx="200" dy="50"/> -->
        </None>     
	</Geometry>
	<Model>

    <Params
        Density_h="1.0" Density_l="1.0" 
        Viscosity_h="1.0" Viscosity_l="1.0"
        PhaseField_h="1.0" PhaseField_l="0.0" 
        ContactAngle="135" 
      
        PhaseField_init="0.0"
        PhaseField_init-bubble="1.0"
        PhaseField_init-sciana="0.0"

        W="5" M="0.05" sigma="5e-5"
        />
    <Params  />
     <Params omega_bulk="1.0"/>
<!--     <Params GravitationY="4.17E-10" />
    <Params GravitationX="4.07E-08" /> -->
    <Params GravitationX="1E-06" />
    </Model> 
    <Solve Iterations="25" output="output/"> <VTK Iterations="5"/> </Solve>

<Geometry>
  <None mask="ADDITIONALS">
    <Box nx="256" ny="256"/>
  </None>
</Geometry>
<Solve Iterations="50" output="output/"> <VTK Iterations="10"/> </Solve>
<Failcheck Iterations="1000" nx="256" ny="256"/>
<Solve Iterations="20000" output="output/"> <VTK Iterations="500"/> </Solve>
</CLBConfig>
