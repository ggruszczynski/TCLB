 
<?xml version="1.0"?>
<CLBConfig version="2.0" output="output/">
        <Geometry nx="256" ny="256">
        <MRT><Box/></MRT>
        <Smoothing><Box /></Smoothing> 
        <None name="bubble">
                    <Sphere ny="56" nx="56" dx="100" dy="100"/>
        </None>     
                <Wall mask="ALL" name="border" >
                        <Box nx="1"/>
                        <Box dx="-1"/>
                        <Box ny="1"/>
                        <Box dy="-1"/>
                </Wall>
             
        </Geometry>
    <Model>
    <Params
        Density_h="1.0" Density_l="0.1" 
        Viscosity_h="1.0" Viscosity_l="1.0"
        PhaseField_h="1.0" PhaseField_l="0.0" 
        ContactAngle="135" 
      
        PhaseField_init="0.0"
        PhaseField_init-bubble="1.0"
        PhaseField_init-sciana="0.0"

        W="5" M="0.05" sigma="5e-5"
        />
    <Params  />
     <Params omega_bulk="1.0"/>
<!--     <Params GravitationY="4.17E-10" />
    <Params GravitationX="4.07E-08" /> -->
    </Model> 
    <Solve Iterations="25" output="output/"> <VTK Iterations="5"/> </Solve>

<Geometry>
  <None mask="ADDITIONALS">
    <Box nx="256" ny="256"/>
  </None>
</Geometry>
<Solve Iterations="50" output="output/"> <VTK Iterations="10"/> </Solve>
<Failcheck Iterations="1000" nx="256" ny="256"/>
<Solve Iterations="20000" output="output/"> <VTK Iterations="500"/> </Solve>
</CLBConfig>
