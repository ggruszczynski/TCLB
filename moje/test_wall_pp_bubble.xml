<?xml version="1.0"?>
<CLBConfig version="2.0" output="output/">
    <Geometry nx="128" ny="128">
    <MRT><Box /></MRT>
    <Smoothing><Box /></Smoothing> 
        <None name="bubble">
            <!-- <Sphere ny="30" nx="30" dx="80" dy="-50"/> -->
            <Sphere ny="30" nx="30" dx="40" dy="92"/>
        </None> 


    <Wall mask="ALL" name="sciana">
        <Box dy="-2"/>
        <Box ny="2"/>
        <Box nx="2"/>
        <Box dx="-2"/>
    </Wall>

  </Geometry>
    <Model>
    <Params

    	Density_h="10.0" Density_l="0.0122" 
        Viscosity_h="0.5" Viscosity_l="7.5"
        PhaseField_h="1.0" PhaseField_l="0.0" 
       
      
        PhaseField_init="1.0"
        PhaseField_init-sciana="1.0"
        PhaseField_init-bubble="0.0"
 


        G_sf="-0.007"

        W="4" M="0.05" sigma="5e-5"
        />
    <Params  />
        <Params GravitationY="-2e-8" />
        <!-- <Params VelocityX-Inlet="0.00316404907"/> -->
    </Model> 
        <Solve Iterations="20" output="output/"> <VTK Iterations="1"/> </Solve>

<Geometry>
  <None mask="ADDITIONALS">
    <Box nx="128" ny="128"/>
  </None>
</Geometry>

<Solve Iterations="50" output="output/"> <VTK Iterations="1"/> </Solve>
<Failcheck Iterations="1000" nx="128" ny="128"/>
<Solve Iterations="20000" output="output/"> <VTK Iterations="500"/> </Solve>
</CLBConfig>