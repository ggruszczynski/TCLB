<?xml version="1.0"?>
<CLBConfig version="2.0" output="output/">
    <Geometry nx="128" ny="128">
    <MRT><Box /></MRT>
    <Smoothing><Box /></Smoothing> 
<!--         <WVelocity name="Inlet" nx='1' dx='5'><Box/></WVelocity>
        <Convective_E name="Outlet" nx='1' dx='-5'><Box/></Convective_E> -->

        <None name="air">
        	<Sphere ny="30" nx="30" dx="80" dy="-50"/>
            <Sphere ny="30" nx="30" dx="40" dy="5"/>
        </None> 


    <Wall mask="ALL" name="sciana">
        <Box dy="-2"/>
        <Box ny="2"/>
        <Box nx="2"/>
        <Box dx="-2"/>
    </Wall>

  </Geometry>
    <Model>
    <Params
        Density_h="1.0" Density_l="0.122" 
        Viscosity_h="1.0" Viscosity_l="15.0"
        PhaseField_h="1.0" PhaseField_l="0.0" 
      
        PhaseField_init="0.0"
        PhaseField_init-air="1.0"

        PhaseField_init-sciana="0.0"


        G_sf="-0.002"

        W="4" M="0.05" sigma="5e-5"
        />
    <Params  />
        <!-- <Params GravitationY="-0.00001" /> -->
        <!-- <Params VelocityX-Inlet="0.00316404907"/> -->
    </Model> 
        <Solve Iterations="20" output="output/"> <VTK Iterations="1"/> </Solve>

<Geometry>
  <None mask="ADDITIONALS">
    <Box nx="128" ny="128"/>
  </None>
</Geometry>

<Solve Iterations="50" output="output/"> <VTK Iterations="1"/> </Solve>
<Failcheck Iterations="1000" />
<Solve Iterations="25000" output="output/"> <VTK Iterations="500"/> </Solve>
</CLBConfig>


