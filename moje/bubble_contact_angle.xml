<?xml version='1.0' encoding='utf-8'?>
<CLBConfig output="output/" version="2.0">
  <Geometry nx="200" ny="50">
    <MRT>
      <Box />
    </MRT>
      <WPressure name="inlet" nx='1' dx='5'><Box/></WPressure>
      <EPressure name="outlet" nx='1' dx='-5'><Box/></EPressure>
    <Wall mask="ALL" name="upper_wall">
      <Box dy="-1" />
    </Wall>
    <Wall mask="ALL" name="bottom_wall">
      <Box ny="1" />
      <Box dx="36" fy="20" nx="3" />
    </Wall>
  </Geometry>
  <Model>
    <Params 
		ContactAngle="135"
		BubbleType="1"
		Density_h="1" Density_l="0.08" 
		Pressure="0.1"
		M="0.05" 
		PhaseField_h="1.0" PhaseField_init="0.0" PhaseField_l="0.0" 
		Viscosity_h="0.3333333333333333" Viscosity_l="0.4166666666666667"
		W="5" sigma="5e-05" />
	<Params Pressure-inlet="0.001"/>
	<Params Pressure-outlet="0.0001"/>
	<!-- <Params GravitationX="5e-07"/> -->
    <Params 
      Radius="24"
      CenterX="100"
      CenterY="10" />
  </Model>
  <Failcheck Iterations="99" />
  <Solve Iterations="100">
    <VTK Iterations="1" />
    <Log Iterations="1000" />
  </Solve>
</CLBConfig>


