<?xml version="1.0"?>
<CLBConfig version="2.0" output="output/">
        <Geometry nx="256" ny="100">
		<MRT><Box/></MRT>
		<WPressure name="Inlet"><Inlet/></WPressure>
		<EPressure name="Outlet"><Outlet/></EPressure>
		<Inlet nx='1' dx='5'><Box/></Inlet>
		<Outlet nx='1' dx='-5'><Box/></Outlet>
		<Wall mask="ALL">
			<Channel/>
			<Wedge dx="120" nx="20" dy="50" ny="20" direction="LowerRight"/>
			<Wedge dx="120" nx="20" dy="30" ny="20" direction="UpperRight"/>
			<Wedge dx="140" nx="20" dy="50" ny="20" direction="LowerLeft"/>
			<Wedge dx="140" nx="20" dy="30" ny="20" direction="UpperLeft"/>
		</Wall>
		<Wall mask="ALL" name="upper_wall">
			<Box dy="-1" />
		</Wall>
		<Wall mask="ALL" name="bottom_wall">
			<Box ny="1" />
		</Wall>
	</Geometry>
	<Model>
		<!-- <Params VelocityX="0.001"/> -->
		<Params Pressure-Inlet="0.001"/>
		<Params Pressure-Outlet="0.0001"/>
		<Params Viscosity="0.02"/>
		<Params InletTemperature="1"
			InitTemperature="0"
			FluidAlfa="0.01"
			SolidAlfa="0.166"
			Coriolis="0.001"
			Tension="0.01"
			EOSScale="0.05"
			PressDiffInObj="1"
			Smag="0.16"
		/>
	</Model>
	<VTK Iterations="1000"/>
	<Solve Iterations="50000"/>
</CLBConfig>
